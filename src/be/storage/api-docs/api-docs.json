                        "example": "0x1234567890abcdef1234567890abcdef12345678"
                    },
                    "tokenName": {
                        "description": "The name of the token",
                        "type": "string",
                        "example": "MyToken"
                    },
                    "tokenSymbol": {
                        "description": "The symbol of the token",
                        "type": "string",
                        "example": "MTK"
                    },
                    "tokenTotalSupply": {
                        "description": "Total supply of the token (decimal value supported)",
                        "type": "number",
